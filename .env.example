# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
# Публичный адрес сайта — используется для генерации ссылки отмены в письме клиенту
# В проде: https://mateevspa.md
SITE_URL=https://mateevspa.md

# ─── Admin ────────────────────────────────────────────────────────────────────
# REQUIRED. PIN для входа в /admin. Минимум 6 цифр, не используйте простые комбинации.
ADMIN_PIN=

# Срок жизни сессии администратора в часах (по умолчанию 12)
# ADMIN_SESSION_TTL_HOURS=12

# REQUIRED. Случайная строка для подписи сессионных куков.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# ─── Booking form ─────────────────────────────────────────────────────────────
# Случайная строка для подписи CSRF-токенов формы (по умолчанию = ADMIN_SESSION_SECRET).
# Рекомендуется задать отдельно.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FORM_TOKEN_SECRET=

# Минимальное время между открытием формы и отправкой в мс (по умолчанию 4000)
# FORM_MIN_SUBMIT_MS=4000

# Максимальный возраст формы в мс (по умолчанию 12 часов)
# FORM_MAX_AGE_MS=43200000

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Макс. записей с одного IP за окно (по умолчанию 6 за 10 минут)
# BOOKING_RATE_LIMIT=6
# BOOKING_RATE_WINDOW_MS=600000

# Макс. попыток входа в админку (по умолчанию 8 за 15 минут)
# ADMIN_LOGIN_RATE_LIMIT=8
# ADMIN_LOGIN_RATE_WINDOW_MS=900000

# ─── Cookies ──────────────────────────────────────────────────────────────────
# Установить в "true" в проде (требует HTTPS)
COOKIE_SECURE=true

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
# Через запятую, если несколько получателей
EMAIL_NOTIFICATIONS_TO=

# ─── Backups ──────────────────────────────────────────────────────────────────
# Сколько бэкапов хранить на файл (по умолчанию 30)
# BACKUP_RETENTION_PER_FILE=30

# ─── Прочее ───────────────────────────────────────────────────────────────────
# Таймаут исходящих HTTP-запросов в мс (по умолчанию 8000)
# HTTP_OUTBOUND_TIMEOUT_MS=8000
